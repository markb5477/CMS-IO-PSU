# Config for the BERT status exporter. Copy to .env and edit on cmsladdertest.
# Every value has a default (see config.py); set only what you need to change.

# --- HTTP endpoint Prometheus scrapes (via the psu-tunnel sidecar) ---
BERT_LISTEN=127.0.0.1
BERT_HTTP_PORT=9821
BERT_POLL_INTERVAL=2

# --- Which CSV to follow ---------------------------------------------------
# mm_acf writes it to a run-specific dir, e.g.:
#   <cwd or $GIPHT_RESULT_FOLDER>/Results/OT_ModuleTest_<ModuleId>_Run<N>/bertContinuous.csv
# The basename is always bertContinuous.csv, so by default we follow the NEWEST
# match under BERT_RESULTS_ROOT and switch automatically when a new run starts.
#
# Point BERT_RESULTS_ROOT at wherever the DAQ is launched from (its Results/ lives
# under the working dir unless $GIPHT_RESULT_FOLDER / $OTSDAQ_RESULTS_FOLDER is set).
BERT_RESULTS_ROOT=/home/xtaldaq/mm_acf
BERT_GLOB=**/bertContinuous.csv

# Or pin one exact file once you know the on-site path (this WINS over the glob):
# BERT_CSV=/home/xtaldaq/mm_acf/Results/OT_ModuleTest_M123_Run7/bertContinuous.csv

# --- Robustness knobs (usually leave at defaults) --------------------------
# The DAQ writes hardware read-failure sentinels into the CSV; the exporter maps
# them to NaN (a gap in Grafana) instead of a bogus value.
#   errorCount == 4294967295 (0xFFFFFFFF)  -> FPGA error-counter read never stabilised
#   testedBits  > 1e15                      -> frame-counter read failed (0xFFFF... * float)
# Set BERT_ERROR_SENTINEL negative to disable the first check (e.g. if you'd rather
# see a genuinely saturated 32-bit counter as 4.29e9); set BERT_MAX_TESTED_BITS<=0
# to disable the second.
# BERT_ERROR_SENTINEL=4294967295
# BERT_MAX_TESTED_BITS=1e15
