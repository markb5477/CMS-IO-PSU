# Shared config for the PSU-server tools. Copy to .env and edit; the exporter,
# psuctl and experiments all read it. Real environment variables override it.

# PSU connection (exporter only). PSU is on a private USB-ethernet link to this
# PC, static: PSU 192.168.50.2, PC dongle 192.168.50.1/24. See GUIDE.md.
PSU_HOST=192.168.50.2
PSU_PORT=9221

# Exporter HTTP endpoint: LISTEN is where the exporter binds; HTTP_HOST/PORT is
# where psuctl and the experiments reach it (localhost - /control is local-only).
LISTEN=0.0.0.0
HTTP_HOST=127.0.0.1
HTTP_PORT=9820
POLL_INTERVAL=1.0

# Safety ceilings protecting the load. DISABLED: raised far past the PSU's real
# max (60V/10A) so they never interrupt (paired with the loosened HW_MAX_* in
# exporter.py). Tighten to the detector's V/I tolerance to re-enable protection.
MAX_VOLTAGE=100000.0
MAX_CURRENT=100000.0
