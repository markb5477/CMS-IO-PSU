# Config for the monitoring stack. Copy to .env and edit.
# Scrape-job values are baked into prometheus.yml by ./render.sh (at deploy time);
# the PORT/PASSWORD values are read by docker-compose at ./on.sh time on the host.

# --- Prometheus scrape job (used by render.sh) ---
# :9820 is firewalled for a direct scrape, so we scrape the psu-tunnel sidecar.
# If a firewall opening is ever granted, set this back to cmsladdertest.dyndns.cern.ch:9820.
PSU_EXPORTER_TARGET=psu-tunnel:9820
SCRAPE_INTERVAL=4s
INSTRUMENT=cpx200dp
LOCATION=186-B-04

# --- SSH reverse tunnel to the lab PC (used by the psu-tunnel sidecar) ---
TUNNEL_SSH_TARGET=xtaldaq@cmsladdertest.dyndns.cern.ch
TUNNEL_REMOTE_HOSTPORT=127.0.0.1:9820

# --- Docker stack (used by docker-compose / on.sh) ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme
