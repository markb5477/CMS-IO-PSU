    {
      "type": "timeseries",
      "title": "Bit error rate per 1 s window (0 = no errors that window)",
      "id": 7,
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "cpx-prometheus"
      },
      "targets": [
        {
          "expr": "bert_bit_error_rate",
          "legendFormat": "b{{board}}/h{{hybrid}}/L{{line}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "sci",
          "custom": {
            "fillOpacity": 0,
            "showPoints": "auto",
            "lineInterpolation": "stepAfter",
            "scaleDistribution": {
              "type": "symlog",
              "log": 10,
              "linearThreshold": 1e-12
            }
          },
          "mappings": [],
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "description": "Per-window BER. Resolution floor is 1/testedBits ~ 3e-9, so 0 here only means 'no error in this second'. For the real sensitivity see the 95% CL limit panels above."
    },
    {
      "type": "timeseries",
      "title": "lpGBT FEC corrections per link",
      "description": "Forward error correction repairs bit flips silently, so a climbing FEC count is link degradation the PRBS error count cannot see - it stays at 0 precisely because FEC fixed the frame. Solid = uplink, dashed = downlink.",
      "id": 17,
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "cpx-prometheus"
      },
      "targets": [
        {
          "expr": "bert_fec_uplink",
          "legendFormat": "up b{{board}}/h{{hybrid}}/L{{line}}",
          "refId": "A"
        },
        {
          "expr": "bert_fec_downlink",
          "legendFormat": "down b{{board}}/h{{hybrid}}/L{{line}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 5,
            "showPoints": "never",
            "lineInterpolation": "stepAfter"
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "down .*"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
