  "title": "OT Module BER - cmsladdertest",
  "uid": "ot-bert",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "schemaVersion": 39,
  "tags": [
    "bert",
    "tracker",
    "cleanroom"
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
