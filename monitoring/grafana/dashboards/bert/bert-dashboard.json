    {
      "id": 11,
      "type": "stat",
      "title": "Bits tested (this run)",
      "description": "Sum of every measurement window in the current Run_<N>, all links. Resets when the DAQ starts a new run.",
      "datasource": {
        "type": "prometheus",
        "uid": "cpx-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
