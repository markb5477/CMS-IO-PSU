    {
      "id": 15,
      "type": "stat",
      "title": "FEC uplink, worst link (this run)",
      "description": "Uplink Worst link this run, not a sum - the counter is per optical group so the DAQ repeats it on every hybrid sharing it. Amber means any correction at all happened, which is a look-at-me, not a spec limit. Empty = the CSV has no FEC column (runs before Run_43).",
      "datasource": {
        "type": "prometheus",
        "uid": "cpx-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
