    {
      "id": 18,
      "type": "stat",
      "title": "Downlink optical power, lowest link (this run)",
      "description": "Received light at the module, raw lpGBT monitoring-ADC counts (~10-bit, typically ~583) - NOT calibrated to uW. This is the LOWEST reading on any link this run; a falling value is the early sign of a dirty or failing fibre. No alarm threshold is set because the counts are uncalibrated. Empty = the run predates the opticalPowerDownlink column.",
      "datasource": {
        "type": "prometheus",
        "uid": "cpx-prometheus"
