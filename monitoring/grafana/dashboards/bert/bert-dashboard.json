        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "BER upper limit per link, 95% CL (falls with exposure)",
      "description": "Per-link 95% CL limit over the run. A healthy link shows a smoothly falling curve; a link that takes an error steps up.",
      "datasource": {
        "type": "prometheus",
        "uid": "cpx-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 9
