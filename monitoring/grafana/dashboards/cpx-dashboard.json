{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "CPX200DP Power Supply - 186/B-04",
  "uid": "cpx200dp",
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "schemaVersion": 39,
  "tags": ["psu", "cleanroom"],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "PSU reachable",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "cpx_up", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Output 1",
      "id": 2,
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "cpx_output_enabled{channel=\"1\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ON", "color": "green" }, "0": { "text": "OFF", "color": "text" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Output 2",
      "id": 3,
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "cpx_output_enabled{channel=\"2\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ON", "color": "green" }, "0": { "text": "OFF", "color": "text" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Regulation mode",
      "id": 4,
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "cpx_constant_current", "legendFormat": "ch {{channel}}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "CC", "color": "orange" }, "0": { "text": "CV", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Trips (OVP/OCP)",
      "id": 5,
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "sum(cpx_trip_overvoltage) + sum(cpx_trip_overcurrent)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Total output power",
      "id": 6,
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "sum(cpx_output_power_watts)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "colorMode": "none", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Voltage",
      "id": 7,
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "cpx_output_voltage_volts", "legendFormat": "ch {{channel}} out", "refId": "A" },
        { "expr": "cpx_set_voltage_volts", "legendFormat": "ch {{channel}} set", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": { "fillOpacity": 5, "showPoints": "never" },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*set.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [6, 4], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Current",
      "id": 8,
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "cpx_output_current_amps", "legendFormat": "ch {{channel}} out", "refId": "A" },
        { "expr": "cpx_set_current_amps", "legendFormat": "ch {{channel}} limit", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "custom": { "fillOpacity": 5, "showPoints": "never" },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*limit.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [6, 4], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Output power",
      "id": 9,
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "cpx-prometheus" },
      "targets": [
        { "expr": "cpx_output_power_watts", "legendFormat": "ch {{channel}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "fillOpacity": 10, "showPoints": "never" },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
