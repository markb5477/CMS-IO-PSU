# Full Prometheus config for the CPX PSU monitoring stack.
# Generated from prometheus.yml.tmpl by ../render.sh - edit the template, not the output.
global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: cpx_psu
    scrape_interval: ${SCRAPE_INTERVAL}
    static_configs:
      - targets: ["${PSU_EXPORTER_TARGET}"]
        labels:
          instrument: ${INSTRUMENT}
          location: ${LOCATION}
